CREATE DATABASE IF NOT EXISTS sistema_citas;
USE sistema_citas;

DROP TABLE IF EXISTS USUARIO;
CREATE TABLE USUARIO (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(100) NOT NULL UNIQUE,
    clave VARCHAR(100) NOT NULL,
    rol ENUM('PACIENTE','MEDICO','ADMINISTRADOR') NOT NULL
) ENGINE=InnoDB;

DROP TABLE IF EXISTS MEDICO;
CREATE TABLE MEDICO (
    id INT PRIMARY KEY,
    especialidad VARCHAR(100) NOT NULL,
    ciudad VARCHAR(100) NOT NULL,
    costo_consulta INT NOT NULL,
    frecuencia INT NOT NULL,
    instalacion VARCHAR(100) NOT NULL,
    estado VARCHAR(20) NOT NULL,
    imagen VARCHAR(255),
    CONSTRAINT fk_medico_usuario
        FOREIGN KEY (id)
        REFERENCES USUARIO (id)
        ON DELETE CASCADE
        ON UPDATE CASCADE
) ENGINE=InnoDB;

DROP TABLE IF EXISTS PACIENTE;
CREATE TABLE PACIENTE (
    id INT AUTO_INCREMENT PRIMARY KEY,
    CONSTRAINT fk_paciente_usuario
        FOREIGN KEY (id)
        REFERENCES USUARIO (id)
        ON DELETE CASCADE
        ON UPDATE CASCADE
) ENGINE=InnoDB;

DROP TABLE IF EXISTS HORARIO;
CREATE TABLE HORARIO (
    numero INT AUTO_INCREMENT PRIMARY KEY,
    doctor_id INT NOT NULL,
    dia INT NOT NULL CHECK (dia BETWEEN 1 AND 7),
    horainicio INT NOT NULL,
    horafin INT NOT NULL,
    CHECK (horainicio < horafin),
    CONSTRAINT fk_horario_medico
        FOREIGN KEY (doctor_id)
        REFERENCES MEDICO(id)
        ON DELETE CASCADE
        ON UPDATE CASCADE
) ENGINE=InnoDB;

DROP TABLE IF EXISTS CITA;
CREATE TABLE CITA (
    numero INT AUTO_INCREMENT PRIMARY KEY,
    doctor_id INT NOT NULL,
    paciente_id INT NOT NULL,
    fecha_hora DATETIME NOT NULL,
    estado ENUM('CONFIRMADA', 'PENDIENTE', 'CANCELADA') NOT NULL,
    notas TEXT,
    CONSTRAINT fk_cita_medico
        FOREIGN KEY (doctor_id)
        REFERENCES MEDICO(id)
        ON DELETE CASCADE
        ON UPDATE CASCADE,
    CONSTRAINT fk_cita_paciente
        FOREIGN KEY (paciente_id)
        REFERENCES PACIENTE(id)
        ON DELETE CASCADE
        ON UPDATE CASCADE
) ENGINE=InnoDB;
